config system
	option hostname 'HXZN'
	option ttylogin '0'
	option log_size '64'
	option urandom_seed '0'
	option timezone 'CST-8'
	option zonename 'Asia/Shanghai'
	option log_proto 'udp'
	option conloglevel '8'
	option cronloglevel '8'

config timeserver 'ntp'
	option enabled '1'
	list server 'ntp.tencent.com'
	list server 'ntp1.aliyun.com'
	list server 'ntp.ntsc.ac.cn'
	list server 'cn.ntp.org.cn'

config led 'led_wan'
	option name 'WAN'
	option trigger 'netdev'
	option mode 'link tx rx'
	option dev 'eth0'
	option sysfs 'm2:blue:mesh'
	option default '0'

config led 'led_wlan2g'
	option trigger 'netdev'
	option mode 'link tx rx'
	option name 'LAN1'
	option sysfs 'm2:blue:lan'
	option default '0'
	option dev 'eth3'

config led 'led_wlan5g'
	option trigger 'netdev'
	option mode 'link tx rx'
	option name 'LAN2'
	option sysfs 'm2:blue:wan'
	option default '0'
	option dev 'eth2'

config led
	option default '0'
	option name 'LAN3'
	option trigger 'netdev'
	option dev 'eth1'
	option mode 'link tx rx'
	option sysfs 'm2:blue:wlan5g'
